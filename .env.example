# =============================================================================
# TG-Ticket-Agent Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Port for the main application (REQUIRED for Dokploy)
PORT=3000

# Environment: development | production
ENV=production

# Debug mode (true/false)
DEBUG=false

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL connection URL
DATABASE_URL=postgresql://postgres:your_secure_password@postgres:5432/tg_ticket_agent

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=tg_ticket_agent

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Telegram Bot Configuration
# -----------------------------------------------------------------------------
# Get your bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Webhook URL for production (set to your domain)
# Leave empty for polling mode in development
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/webhooks/telegram

# Bot username (without @)
TELEGRAM_BOT_USERNAME=your_bot_username

# -----------------------------------------------------------------------------
# Bill24/TixGear API Configuration
# -----------------------------------------------------------------------------
# Test environment URL (port 1240)
BILL24_TEST_URL=https://api.tixgear.com:1240/json

# Production environment URL
BILL24_REAL_URL=https://api.tixgear.com/json

# Default zone: test | real
BILL24_DEFAULT_ZONE=test

# -----------------------------------------------------------------------------
# Admin Panel Authentication
# -----------------------------------------------------------------------------
# JWT secret key - MUST be changed in production!
# Generate with: openssl rand -hex 32
ADMIN_JWT_SECRET=change_this_to_a_secure_random_string_in_production

# JWT token expiration
ADMIN_JWT_EXPIRES_IN=24h

# Default admin credentials (created on first run)
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change_me_on_first_login

# -----------------------------------------------------------------------------
# Webhook Integration (n8n, etc.)
# -----------------------------------------------------------------------------
# n8n webhook URL for user/purchase events
N8N_WEBHOOK_URL=

# Webhook secret for signature verification
WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log format: json | text
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable specific features
ENABLE_TICKET_PDF=true
ENABLE_WEBHOOKS=true
ENABLE_EVENT_CACHING=true

# Event cache TTL in seconds (default: 15 minutes)
EVENT_CACHE_TTL=900
